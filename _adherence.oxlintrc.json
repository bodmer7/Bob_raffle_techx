{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/collectible/**",
              "components/core/**",
              "ui_kits/capsule-game/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Saira Condensed|IBM Plex Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Saira Condensed, IBM Plex Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|full|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, full, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger|exotic)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger' | 'exotic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Capsule'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|series|hint|size|floating|style|key|ref|className|style|children)$/]",
        "message": "<Capsule> doesn't accept that prop. Declared props: name, series, hint, size, floating, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Capsule'] > JSXAttribute[name.name='hint'] > Literal[value!=/^(?:standard|rare|epic|legendary|exotic)$/]",
        "message": "<Capsule> hint must be one of 'standard' | 'rare' | 'epic' | 'legendary' | 'exotic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|showValue|tone|height|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, label, showValue, tone, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|rarity)$/]",
        "message": "<ProgressBar> tone must be one of 'accent' | 'rarity'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RarityBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tier|label|size|variant|style|key|ref|className|style|children)$/]",
        "message": "<RarityBadge> doesn't accept that prop. Declared props: tier, label, size, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RarityBadge'] > JSXAttribute[name.name='tier'] > Literal[value!=/^(?:standard|rare|epic|legendary|exotic)$/]",
        "message": "<RarityBadge> tier must be one of 'standard' | 'rare' | 'epic' | 'legendary' | 'exotic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RarityBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<RarityBadge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RarityBadge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|soft|bar)$/]",
        "message": "<RarityBadge> variant must be one of 'solid' | 'soft' | 'bar'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|icon|tone|size|style|key|ref|className|style|children)$/]",
        "message": "<StatPill> doesn't accept that prop. Declared props: label, value, icon, tone, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|success|rarity)$/]",
        "message": "<StatPill> tone must be one of 'neutral' | 'accent' | 'success' | 'rarity'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<StatPill> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StickerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|image|tier|finish|count|isNew|locked|width|onClick|style|key|ref|className|style|children)$/]",
        "message": "<StickerCard> doesn't accept that prop. Declared props: name, image, tier, finish, count, isNew, locked, width, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StickerCard'] > JSXAttribute[name.name='tier'] > Literal[value!=/^(?:standard|rare|epic|legendary|exotic)$/]",
        "message": "<StickerCard> tier must be one of 'standard' | 'rare' | 'epic' | 'legendary' | 'exotic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StickerCard'] > JSXAttribute[name.name='finish'] > Literal[value!=/^(?:none|holo|foil)$/]",
        "message": "<StickerCard> finish must be one of 'none' | 'holo' | 'foil'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
